# WeChat Official Account Configuration
# 微信公众号配置

WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# Optional: Default cover image media_id
# 可选：默认封面图的media_id（需先上传到微信素材库）
WECHAT_DEFAULT_THUMB_MEDIA_ID=

# OpenAI Configuration (for Pro features)
# OpenAI配置（Pro功能需要）
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4

# Publishing Configuration
# 发布配置
DEFAULT_AUTHOR=AI助手
AUTO_PUBLISH=true

# Schedule Configuration
# 定时配置
SCHEDULE_ENABLED=false
SCHEDULE_TIME=08:00

# Pro Features (set to true to enable)
# Pro功能（设置为true启用）
ENABLE_AI_CONTENT=false
ENABLE_AI_COVER=false
ENABLE_ANALYTICS=false

# Logging
# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/wechat_publisher.log
