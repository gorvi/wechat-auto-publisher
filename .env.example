# WeChat Official Account Configuration
# 微信公众号配置

WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# Optional: Default cover image media_id
# 可选：默认封面图的media_id（需先上传到微信素材库）
WECHAT_DEFAULT_THUMB_MEDIA_ID=

# AI Content Generation (choose one or configure multiple)
# AI内容生成（选择一种或配置多种）

# Option 1: Google Gemini (Recommended - free tier available)
# 选项1：Google Gemini（推荐 - 有免费额度）
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI GPT-4
# 选项2：OpenAI GPT-4
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4

# Option 3: Google Vertex AI / Imagen (for AI cover images)
# 选项3：Google Vertex AI（用于AI封面图）
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1

# Publishing Configuration
# 发布配置
DEFAULT_AUTHOR=AI助手
AUTO_PUBLISH=false

# Schedule Configuration
# 定时配置
SCHEDULE_ENABLED=false
SCHEDULE_TIME=08:00

# Pro Features (set to true to enable)
# Pro功能（设置为true启用）
ENABLE_AI_CONTENT=false
ENABLE_AI_COVER=false
ENABLE_ANALYTICS=false

# Logging
# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/wechat_publisher.log
